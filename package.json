{
    "name": "salesforce-pubsub-api-client",
    "version": "5.5.2",
    "type": "module",
    "description": "A node client for the Salesforce Pub/Sub API",
    "author": "pozil",
    "license": "CC0-1.0",
    "homepage": "https://github.com/pozil/pub-sub-api-node-client",
    "main": "dist/client.js",
    "exports": {
        ".": {
            "types": "./dist/client.d.ts",
            "require": "./dist/client.cjs",
            "import": "./dist/client.js"
        }
    },
    "scripts": {
        "build": "tsup && tsc",
        "test": "jasmine",
        "format": "prettier --write '**/*.{css,html,js,json,md,yaml,yml}'",
        "format:verify": "prettier --check '**/*.{css,html,js,json,md,yaml,yml}'",
        "lint": "eslint \"src/**\" \"spec/**\"",
        "prepare": "husky || true",
        "precommit": "lint-staged",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.14.3",
        "@grpc/proto-loader": "^0.8.1",
        "avro-js": "^1.12.1",
        "jsforce": "^3.10.14",
        "undici": "^8.2.0"
    },
    "devDependencies": {
        "@chialab/esbuild-plugin-meta-url": "^0.19.1",
        "dotenv": "^17.4.2",
        "eslint": "^9.39.2",
        "eslint-plugin-jasmine": "^4.2.2",
        "husky": "^9.1.7",
        "jasmine": "^6.2.0",
        "lint-staged": "^17.0.4",
        "prettier": "^3.8.3",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "lint-staged": {
        "**/*.{css,html,js,json,md,yaml,yml}": [
            "prettier --write"
        ],
        "**/{src,spec}/**/*.js": [
            "eslint"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pozil/pub-sub-api-node-client.git"
    },
    "keywords": [
        "salesforce",
        "pubsub",
        "api",
        "grpc"
    ],
    "files": [
        "dist/*",
        "pubsub_api.proto"
    ],
    "volta": {
        "node": "22.22.2"
    }
}
